#!/usr/bin/env bash
# d1q — run `wrangler d1 …` for the d1-jdbc-driver's SSH (proxy) transport,
# keeping stdout pure JSON.
#
# The driver's proxy transport runs `ssh hawk d1q d1 execute …` and parses
# stdout as the `wrangler --json` array. Two things get in the way that this
# wrapper handles, so the Mac-side JDBC URL can stay minimal
# (transport=ssh&host=hawk&db=…&mode=local|remote, wrangler=d1q):
#
#   1. wrangler/dotenv prints a "loaded .env" banner to stdout — stripped here
#      (everything before the first JSON line is dropped).
#   2. --config and (for --local) --persist-to are injected from the project so
#      the URL need not carry absolute paths. The CF API token for --remote is
#      sourced by wrangler itself from the project's .env.
#
# Override the project via env: D1Q_PROJECT, D1Q_CONFIG, D1Q_PERSIST.
set -euo pipefail

PROJECT="${D1Q_PROJECT:-/home/draven/columbus/projects/kuaitu/main}"
CONFIG="${D1Q_CONFIG:-${PROJECT}/edge/worker/wrangler.jsonc}"
PERSIST="${D1Q_PERSIST:-${PROJECT}/.wrangler/state}"

args=("$@")
# Inject --config unless the caller already supplied one.
case " ${args[*]} " in
  *" --config "*) ;;
  *) args+=(--config "${CONFIG}") ;;
esac
# Local mode must point at the dev DB state, or wrangler opens a fresh default.
case " ${args[*]} " in
  *" --local "*)
    case " ${args[*]} " in
      *" --persist-to "*) ;;
      *) args+=(--persist-to "${PERSIST}") ;;
    esac
    ;;
esac

cd "${PROJECT}"
# `pnpm exec` resolves the project-pinned wrangler without entering the dev
# shell (whose shellHook would itself write a banner to stdout). The awk filter
# drops any leading banner so the driver receives only the JSON array/object.
pnpm exec wrangler "${args[@]}" | awk 'seen || /^[[{]/ { seen = 1; print }'
